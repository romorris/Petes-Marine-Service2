---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import ServiceCard from '../components/ServiceCard.astro';
import Icons from '../components/Icons.astro';

const base = import.meta.env.BASE_URL;
const site = 'https://romorris.github.io/Petes-Marine-Service2';
const formspreeNext = `${site}/?sent=1#contact`;

const services = [
  {
    icon: 'tools' as const,
    title: 'Engine Repair & Rebuilds',
    description: 'From minor tweaks to complete overhauls. Yamaha, Mercury, Suzuki, and more — we bring old outboards back to life.',
  },
  {
    icon: 'bolt' as const,
    title: 'Professional Wiring',
    description: 'Installation and repair of marine electrical systems for safety, reliability, and peak efficiency on the water.',
  },
  {
    icon: 'chip' as const,
    title: 'Electronics Installation',
    description: 'GPS, fish finders, VHF radios, and modern electronics installed and configured to your needs.',
  },
  {
    icon: 'sparkle' as const,
    title: 'Boat Cleaning',
    description: 'Detailed interior and exterior cleaning to keep your vessel looking pristine and ready for the weekend.',
  },
  {
    icon: 'trailer' as const,
    title: 'Trailer Repair',
    description: 'Full trailer maintenance — bearings, brakes, lights, and everything between the ramp and the road.',
  },
];
---

<Layout>
  <Header />

  <main>
    <section id="home" class="hero">
      <img
        class="hero-bg"
        src={`${base}img/hero.webp`}
        alt=""
        width="1600"
        height="900"
        fetchpriority="high"
        decoding="async"
      />
      <div class="hero-overlay" aria-hidden="true"></div>
      <div class="hero-content">
        <h2>Pete's Marine Service</h2>
        <p>
          Your one-stop shop for expert outboard engine repair, professional wiring,
          and comprehensive boat maintenance in Palm Beach Gardens, Florida.
        </p>
        <div>
          <a href="#contact" class="btn">Get a Quote</a>
          <a href="tel:+19144951015" class="btn btn-secondary">914-495-1015</a>
        </div>
      </div>
    </section>

    <div class="container">
      <section id="services">
        <div class="section-title">
          <h2>Our Services</h2>
          <p>Top-notch solutions to keep your vessel running smoothly on the water.</p>
        </div>
        <div class="services-grid">
          {services.map((service) => (
            <ServiceCard {...service} />
          ))}
        </div>
      </section>

      <section id="about">
        <div class="about-content">
          <div class="about-text">
            <h2>Why Choose Pete?</h2>
            <p>
              With decades of experience in marine mechanics and electronics, Pete's Marine Service
              provides the expertise and quality parts your boat deserves. From frozen powerheads
              to trailer bearings — honest diagnostics, practical advice, no nonsense.
            </p>
            <p>
              We focus on personalized service and customer satisfaction, all under one roof.
              Whether you need a repower consultation or a full rebuild assessment, we'll tell you
              what makes sense before you spend a dime.
            </p>
            <div class="brands">
              <span class="brand-tag">Yamaha</span>
              <span class="brand-tag">Mercury</span>
              <span class="brand-tag">Suzuki</span>
              <span class="brand-tag">Honda</span>
              <span class="brand-tag">Evinrude</span>
            </div>
          </div>
          <div class="about-image">
            <img
              src={`${base}img/engine.webp`}
              alt="Outboard engine service and repair"
              width="900"
              height="600"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
      </section>

      <section id="contact">
        <div class="section-title">
          <h2>Contact Us</h2>
          <p>Located in Palm Beach Gardens, Florida. Open Mon–Fri, 8AM–5PM.</p>
        </div>
        <div class="contact-container">
          <div class="contact-info">
            <h3>Get In Touch</h3>
            <div class="contact-item">
              <Icons name="phone" />
              <p><a href="tel:+19144951015">914-495-1015</a></p>
            </div>
            <div class="contact-item">
              <Icons name="email" />
              <p><a href="mailto:pete@petes-marine-service.com">pete@petes-marine-service.com</a></p>
            </div>
            <div class="contact-item">
              <Icons name="map" />
              <p>
                <a
                  href="https://maps.google.com/?q=Palm+Beach+Gardens,+FL"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  Palm Beach Gardens, FL
                </a>
              </p>
            </div>
            <div class="contact-item">
              <Icons name="clock" />
              <p>Monday – Friday, 8:00 AM – 5:00 PM</p>
            </div>
            <div class="about-image" style="margin-top: 1.5rem;">
              <img
                src={`${base}img/mechanic.webp`}
                alt="Marine electronics and wiring service"
                width="900"
                height="600"
                loading="lazy"
                decoding="async"
              />
            </div>
          </div>

          <div class="contact-form">
            <div class="form-success" role="status">
              Thanks! Your message was sent. Pete will get back to you soon.
            </div>
            <form action="https://formspree.io/f/mkozdqag" method="POST">
              <input type="hidden" name="_next" value={formspreeNext} />
              <div class="honeypot" aria-hidden="true">
                <label for="website">Website</label>
                <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
              </div>
              <div class="form-group">
                <label for="name">Name</label>
                <input type="text" id="name" name="name" placeholder="Your name" required />
              </div>
              <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" placeholder="your@email.com" required />
              </div>
              <div class="form-group">
                <label for="phone">Phone <span style="font-weight:400;color:#666">(optional)</span></label>
                <input type="tel" id="phone" name="phone" placeholder="Best number to reach you" />
              </div>
              <div class="form-group">
                <label for="message">Message</label>
                <textarea id="message" name="message" placeholder="Tell us about your boat, motor, or trailer…" required></textarea>
              </div>
              <button type="submit" class="btn" style="width:100%">Send Message</button>
            </form>
          </div>
        </div>
      </section>
    </div>
  </main>

  <footer>
    <div class="container">
      <p>&copy; {new Date().getFullYear()} Pete's Marine Service. All rights reserved.</p>
      <p style="margin-top:0.5rem;font-size:0.9rem;">
        <a href="tel:+19144951015" style="color:var(--accent)">914-495-1015</a>
        &nbsp;·&nbsp;
        Palm Beach Gardens, FL
      </p>
    </div>
  </footer>
</Layout>