---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ServiceCard from '../components/ServiceCard.astro';
import Icons from '../components/Icons.astro';

const base = import.meta.env.BASE_URL;
const site = 'https://romorris.github.io/Petes-Marine-Service2';
const formspreeNext = `${site}/?sent=1#contact`;

const services = [
  {
    icon: 'tools' as const,
    title: 'Engine Repair & Rebuilds',
    description: 'From tune-ups to full powerhead work. Yamaha, Mercury, Suzuki, Honda — honest diagnostics before you spend a dollar.',
  },
  {
    icon: 'bolt' as const,
    title: 'Marine Wiring',
    description: 'Safe, clean electrical systems built to handle salt air, vibration, and Florida sun without cutting corners.',
  },
  {
    icon: 'chip' as const,
    title: 'Electronics Installation',
    description: 'GPS, fish finders, VHF radios, and modern helm electronics installed right and explained clearly.',
  },
  {
    icon: 'sparkle' as const,
    title: 'Boat Cleaning',
    description: 'Interior and exterior detailing that gets your vessel weekend-ready — spotless decks, clean consoles, sharp lines.',
  },
  {
    icon: 'trailer' as const,
    title: 'Trailer Repair',
    description: 'Bearings, brakes, lights, and frame work so the trip from ramp to road is as reliable as time on the water.',
  },
];
---

<Layout>
  <Header />

  <main>
    <section id="home" class="hero">
      <img
        class="hero-bg"
        src={`${base}img/hero.webp`}
        alt=""
        width="1600"
        height="900"
        fetchpriority="high"
        decoding="async"
      />
      <div class="hero-overlay" aria-hidden="true"></div>
      <div class="container hero-content">
        <p class="hero-eyebrow">Palm Beach Gardens, Florida</p>
        <h1>Expert care for the boat you depend on.</h1>
        <p class="hero-lead">
          Outboard repair, marine wiring, electronics, cleaning, and trailer service —
          one trusted shop for everything between your ramp and the open water.
        </p>
        <div class="hero-actions">
          <a href="#contact" class="btn btn-primary">Request a Quote</a>
          <a href="tel:+19144951015" class="btn btn-ghost">914-495-1015</a>
        </div>
      </div>
    </section>

    <div class="trust-bar">
      <div class="container trust-grid">
        <div class="trust-item">
          <strong>20+</strong>
          <span>Years Experience</span>
        </div>
        <div class="trust-item">
          <strong>5</strong>
          <span>Service Lines</span>
        </div>
        <div class="trust-item">
          <strong>5+</strong>
          <span>Major Brands</span>
        </div>
        <div class="trust-item">
          <strong>ICW</strong>
          <span>Local &amp; Trusted</span>
        </div>
      </div>
    </div>

    <section id="services" class="section section--cream">
      <div class="container">
        <div class="section-header">
          <span class="section-label">What We Do</span>
          <h2>Full-service marine care</h2>
          <p>
            Everything your boat, motor, and trailer need — under one roof,
            with straight answers and work done right.
          </p>
        </div>
        <div class="services-grid services-grid--five">
          {services.map((service) => (
            <ServiceCard {...service} />
          ))}
        </div>
      </div>
    </section>

    <section id="about" class="section">
      <div class="container">
        <div class="about-grid">
          <div class="about-copy">
            <span class="section-label">Why Pete</span>
            <h2>Mechanics who tell you the truth.</h2>
            <p>
              Pete's Marine Service has spent decades keeping Palm Beach boaters on the water.
              From frozen powerheads to trailer bearings — we diagnose honestly, quote fairly,
              and fix it properly the first time.
            </p>
            <p>
              Need a repower opinion? Wondering if a rebuild is worth it? We'll walk you through
              the real math before you write a check. No upsells. No mystery invoices.
            </p>
            <ul class="about-features">
              <li>Decades of outboard &amp; marine electronics experience</li>
              <li>Honest assessments — rebuild, repower, or walk away</li>
              <li>Quality parts and workmanship you can trust on the ICW</li>
            </ul>
            <div class="brands">
              <span class="brand-tag">Yamaha</span>
              <span class="brand-tag">Mercury</span>
              <span class="brand-tag">Suzuki</span>
              <span class="brand-tag">Honda</span>
              <span class="brand-tag">Evinrude</span>
            </div>
          </div>
          <div class="about-visual">
            <img
              src={`${base}img/engine.webp`}
              alt="Professional outboard engine service"
              width="900"
              height="600"
              loading="lazy"
              decoding="async"
            />
            <div class="about-visual-accent">
              <strong>100%</strong>
              <span>Focused on getting you back on the water.</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="contact" class="section section--dark">
      <div class="container">
        <div class="section-header">
          <span class="section-label">Get In Touch</span>
          <h2>Ready to schedule service?</h2>
          <p>Call, email, or send a message. We respond promptly — Mon–Fri, 8AM–5PM.</p>
        </div>
        <div class="contact-grid">
          <div class="contact-cards">
            <div class="contact-card">
              <div class="contact-card-icon"><Icons name="phone" /></div>
              <div>
                <div class="contact-card-label">Phone</div>
                <a href="tel:+19144951015">914-495-1015</a>
              </div>
            </div>
            <div class="contact-card">
              <div class="contact-card-icon"><Icons name="email" /></div>
              <div>
                <div class="contact-card-label">Email</div>
                <a href="mailto:pete@petes-marine-service.com">pete@petes-marine-service.com</a>
              </div>
            </div>
            <div class="contact-card">
              <div class="contact-card-icon"><Icons name="map" /></div>
              <div>
                <div class="contact-card-label">Location</div>
                <a href="https://maps.google.com/?q=Palm+Beach+Gardens,+FL" target="_blank" rel="noopener noreferrer">
                  Palm Beach Gardens, FL
                </a>
              </div>
            </div>
            <div class="contact-card">
              <div class="contact-card-icon"><Icons name="clock" /></div>
              <div>
                <div class="contact-card-label">Hours</div>
                <p>Monday – Friday, 8AM – 5PM</p>
              </div>
            </div>
          </div>

          <div class="contact-form-panel">
            <h3>Send a message</h3>
            <p>Tell us about your boat, motor, or trailer and we'll get back to you.</p>
            <div class="form-success" role="status">
              Message sent — Pete will be in touch shortly.
            </div>
            <form action="https://formspree.io/f/mkozdqag" method="POST">
              <input type="hidden" name="_next" value={formspreeNext} />
              <div class="honeypot" aria-hidden="true">
                <label for="website">Website</label>
                <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
              </div>
              <div class="form-row">
                <div class="form-group">
                  <label for="name">Name</label>
                  <input type="text" id="name" name="name" placeholder="John Smith" required />
                </div>
                <div class="form-group">
                  <label for="phone">Phone <span class="optional">(optional)</span></label>
                  <input type="tel" id="phone" name="phone" placeholder="(561) 555-0100" />
                </div>
              </div>
              <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" placeholder="you@email.com" required />
              </div>
              <div class="form-group">
                <label for="message">How can we help?</label>
                <textarea id="message" name="message" placeholder="Motor won't start, need wiring work, trailer bearings…" required></textarea>
              </div>
              <button type="submit" class="btn btn-submit">Send Message</button>
            </form>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>