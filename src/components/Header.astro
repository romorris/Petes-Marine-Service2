---
import Icons from './Icons.astro';
const base = import.meta.env.BASE_URL;
---

<header class="site-header" id="site-header">
  <div class="container">
    <nav class="site-nav" aria-label="Main navigation">
      <a href={`${base}#home`} class="logo">
        <div class="logo-mark" aria-hidden="true">P</div>
        <div class="logo-text">
          <span class="logo-name">Pete's Marine</span>
          <span class="logo-tag">Palm Beach Gardens</span>
        </div>
      </a>
      <button class="menu-toggle" type="button" aria-label="Open menu" aria-expanded="false">
        <Icons name="menu" />
      </button>
      <ul class="nav-links">
        <li><a href={`${base}#home`}>Home</a></li>
        <li><a href={`${base}#services`}>Services</a></li>
        <li><a href={`${base}#about`}>About</a></li>
        <li><a href={`${base}#contact`}>Contact</a></li>
        <li><a href="tel:+19144951015" class="nav-cta">914-495-1015</a></li>
      </ul>
    </nav>
  </div>
</header>